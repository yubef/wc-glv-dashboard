# Ambil API key dari API-Football / API-Sports.
# Dashboard tetap bisa jalan tanpa key, tapi hanya tampil data demo.
APIFOOTBALL_KEY=
APIFOOTBALL_BASE=https://v3.football.api-sports.io
APIFOOTBALL_LEAGUE=1
APIFOOTBALL_SEASON=2026

# true = hit endpoint kartu/event per pertandingan selesai.
# Matikan dulu kalau quota API kecil.
ENABLE_EVENT_POINTS=false

# Refresh browser otomatis, default 180000 ms = 3 menit.
NEXT_PUBLIC_AUTO_REFRESH_MS=180000
